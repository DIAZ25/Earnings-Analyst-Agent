# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model to use for all LLM nodes (gpt-4o recommended)
LLM_MODEL=gpt-4o

# ── LangFuse Observability ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required by SEC EDGAR fair-use policy — set to your real email
EDGAR_USER_AGENT=YourName your@email.com

# ── UK Companies House (optional) ─────────────────────────────────────────────
COMPANIES_HOUSE_API_KEY=

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_DIR=data/vector_stores
GUIDANCE_CACHE_DIR=data/guidance_cache

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
